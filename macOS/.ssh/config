Host *
  # Re-add a key into the launchd-managed ssh-agent on use when it is
  # missing, e.g. when the agent was restarted after shell startup
  # See: https://keith.github.io/xcode-man-pages/ssh_config.5.html
  AddKeysToAgent yes
  # Read key passphrases from (and store newly entered ones into) the macOS
  # Keychain, so ssh-add --apple-load-keychain (see ~/.zshrc) keeps working
  # without prompts
  UseKeychain yes
